{
  "printWidth": 80,
  "singleQuote": true,
  "trailingComma": "es5",
  "tabWidth": 2,
  "semi": true,
  "svelteSortOrder": "scripts-markup-styles",
  "svelteStrictMode": true,
  "svelteAllowShorthand": true,
  "plugins": ["prettier-plugin-svelte"],
  "overrides": [
    {
      "files": "**/*.config",
      "options": {
        "printWidth": 120,
        "tabWidth": 4
      }
    },
    {
      "files": "**/*.js",
      "options": {
        "printWidth": 80,
        "singleQuote": false,
        "trailingComma": "all",
        "tabWidth": 2,
        "semi": true
      }
    }
  ]
}
