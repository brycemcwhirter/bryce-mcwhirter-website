{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch SvelteKit",
      "program": "${workspaceFolder}/node_modules/.bin/vite",
      "args": ["dev"],
      "skipFiles": ["<node_internals>/**"],
      "env": {
